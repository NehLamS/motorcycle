R_EFF_MOTOR_GAIN    1 ! [D] Multiplied with calculated value to get Motor efficiency
R_EFF_MOTOR_OFFSET  0 ; - ! [D] Added (after gain) to get Motor efficiency
SPIN_START_R_EFF_MOTOR 0 ; rpm ! [D] Subtracted from motor speed
SPIN_SCALE_R_EFF_MOTOR 1 ! [D] Divided into (motor speed - SPIN_START_R_EFF_MOTOR)
TORQUE_START_R_EFF_MOTOR 0 ; N-m ! [D] Subtracted from motor output torque
TORQUE_SCALE_R_EFF_MOTOR 1 ! [D] Divided into (motor output torque -
                           ! TORQUE_START_R_EFF_MOTOR)

! SPEED_TARGET: Speed controller target. Speed can be a nonlinear CARPET function of
! station and time or a function of time (CONSTANT, COEFFICIENT, or TABLE) combined
! with a function SPEED_TARGET_S of station (CONSTANT, COEFFICIENT, or TABLE).
! Alternatively, a custom equation can be defined at runtime. Speed from the
! calculation can be adjusted with SPEED_TARGET_GAIN and SPEED_TARGET_OFFSET. Time
! used in the calculation can be adjusted with TSCALE_SPEED_TARGET and
! TSTART_SPEED_TARGET. Station used in the calculation can be adjusted with
! SSCALE_SPEED_TARGET and SSTART_SPEED_TARGET. This configurable function supports
! 200 datasets; if indices shown below are not used, e.g., (2), the current value of
! the index ISPEED is used to identify the dataset when reading data.

SPEED_TARGET_ID(1)  1  ! Ramp: 0 to 100 to 0

! Col 1 = time (s), col 2 = speed (km/h)
SPEED_TARGET_TABLE(1) LINEAR_FLAT ! linear interpolation, flat-line extrapolation
 0, 0
 10, 100
 20, 100
 30, 0
ENDTABLE
SPEED_TARGET_GAIN(1) 1 ! [D] Multiplied with calculated value to get speed
SPEED_TARGET_OFFSET(1) 0 ; km/h ! [D] Added (after gain) to get speed
TSTART_SPEED_TARGET(1) 0 ; s ! [D] Subtracted from time
TSCALE_SPEED_TARGET(1) 1 ! [D] Divided into (time - TSTART_SPEED_TARGET)
SPEED_TARGET_COMBINE(1) ADD ! How to combine the two components
SET_UNITS SPEED_TARGET_S_TABLE(1) km/h ;
SPEED_TARGET_S_CONSTANT(1) 0 ; km/h ! Speed component due to station

