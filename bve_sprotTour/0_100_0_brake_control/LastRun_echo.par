M_WHL(2)         14.7 ; kg ! Mass of rear wheel [I]
RAD_TC(2)          70 ; mm ! Crown radius of tire [I]
RRE(2)            311 ; mm ! Effective rolling radius (Vx/AVy) [I]
RR_C(2)         0.004 ; - ! Rolling-resistance coefficient
RR_V(2)       2.5e-05 ; h/km ! Rolling-res. speed coefficient
VHIGH_KAPPA(2)     15 ; km/h ! [D] Max. speed for full long. relaxation
VLOW_ALPHA(2)       5 ; km/h ! Min. speed for full lat. relaxation


!------------------------------------------------------------------------------------
! BRAKES
!------------------------------------------------------------------------------------
! The brake system is specified with the following parameters along with the
! nonlinear Configurable Functions PBK_DL. Open-loop braking can be specified with
