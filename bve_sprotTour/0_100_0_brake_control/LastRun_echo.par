AREA_WC(1)       2050 ; mm2 ! Front brake wheel cylinder area
MU_BK(1)          0.4 ; - ! Front brake pad friction coefficient
RAD_D(1)          148 ; mm ! Front brake disc effective radius

AREA_MC(2)      198.5 ; mm2 ! Rear brake master cylinder area
R_BK(2)             3 ; ratio ! Rear brake lever ratio
TC_BK(2)        0.061 ; s ! Rear brake pressure time constant
AREA_WC(2)       2300 ; mm2 ! Rear brake wheel cylinder area
MU_BK(2)          0.4 ; - ! Rear brake pad friction coefficient
RAD_D(2)           98 ; mm ! Rear brake disc effective radius

!------------------------------------------------------------------------------------
! POWERTRAIN
!------------------------------------------------------------------------------------
! The powertrain model is specified with the following parameters along with
! multiple nonlinear Configurable Functions. Open-loop throttle is specified with
! the function THROTTLE_ENGINE.

INSTALL_POWERTRAIN  1 ! Type: 0 -> Simple, 1 -> Shaft drive, 2 -> Chain drive [I]
OPT_HEV             2 ! Propulsion types: 0 -> internal-combustion engine, 2 ->
                      ! electric, 4 -> parallel hybrid electric
OPT_THROTTLE_DELAY  1 ! Use throttle time constants: 0 -> no, 1 -> yes
INSTALL_ELECTRIC_DRIVE_MOTORS ! VS Command to install electric motors
TC_TH_APP        0.12 ; s ! Time constant for engine throttle application
TC_TH_RELEASE    0.05 ; s ! Time constant for engine throttle release

! The powertrain drive system is specified with the following parameters.

OPT_FINAL_DRIVE_INTERNAL 1 ! Model option for final drive system (shaft or chain): 1
                           ! -> internal model, 0 -> external model
R_EFF_F_FINAL       1 ; - ! Forward efficiency of final gear (shaft drive)
R_EFF_R_FINAL     0.9 ; - ! Reverse efficiency of final gear (shaft drive
IDS_R            0.02 ; kg-m2 ! Spin inertia of rear driveshaft. This is added on
                      ! the transmission inertia.
A_BACKLASH_FINAL    0 ; deg ! Backlash angle of final gear
R_GEAR_FINAL      2.5 ; - ! Gear ratio of final gear (shaft drive) [I]

! The Hybrid/Electric powertrain system parameters.

TC_PWR_HYBRID_AV  0.8 ; s ! Time constant for hybrid/electric available power

! The hybrid/electric powertrain battery parameters.

N_BATTERY          60 ! Number of battery packs [I]
T_BATTERY_INIT     40 ; C ! Initial battery temperature [I]
BATTERY_CHARGE_INIT 0.6 ; - ! Initial battery charged level [I]
V_MOTOR_MIN        60 ; V ! Minimum voltage for electric motor [I]
V_BATTERY_MIN       6 ; V ! Minimum voltage per battery pack [I]
V_BATTERY_MAX       9 ; V ! Maximum voltage per battery pack [I]

! The hybrid/electric power management control parameters.

PWR_EV_MODE        25 ; kW ! Maximum power allowance operated with EV mode [I]
PWR_HEV_DRV_MAX    90 ; kW ! Maximum power available with HEV system (used by speed
                      ! control only) [I]
KPW_PBK_HEV       4.2 ; kW/MPa ! Brake power demand per master cylinder control
                      ! pressure [I]
OPT_REGEN_OFF_THRT  0 ; - ! Charge battery when vehicle is coasting with off
                      ! throttle and off brakeing: 0 -> no, 1 -> yes [I]
CF_HEV_PBK       0.08 ; - ! [D] Control shape factor for regenerative motor power
                      ! around zero speed [I]
VLOW_PWR_TRQ       -1 ; km/h ! [D] Minimum vehicle speed to convert the torque
                      ! command from power demand: -1 -> power demand is divided by
                      ! the trasmission output speed or 10 rad/sec which ever
                      ! larger to convert the torque command, positive value ->
                      ! power demand is divided by the trasmission output speed or
                      ! the trans. output speed based on the specified vehicle
                      ! speed which ever larger to convert the torque command [I]
REGEN_BRK_OFF     0.8 ; - ! Battery charged level to turn off regenerative brake [I]

! The hybrid/electric powertrain motor parameters.

I_MOTOR   0.052559125 ; kg-m2 ! Spin inertia of electric motor [I]
TC_MOTOR         0.05 ; s ! Time constant for electric motor torque

