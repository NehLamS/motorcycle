!------------------------------------------------------------------------------------
! CONFIGURABLE FUNCTIONS
!------------------------------------------------------------------------------------

! CAP_BATTERY_MAX: Battery maximum capacity. Battery full capacity is a function of
! Temperature (CONSTANT, COEFFICIENT, or TABLE). Alternatively, a custom equation can
! be defined at runtime. Battery full capacity from the calculation can be adjusted
! with CAP_BATTERY_MAX_GAIN and CAP_BATTERY_MAX_OFFSET. Temperature used in the
! calculation can be adjusted with TEMP_SCALE_CAP_BATTERY and TEMP_START_CAP_BATTERY.

CAP_BATTERY_MAX_CONSTANT 34 ; A-h ! Battery full capacity
CAP_BATTERY_MAX_GAIN 1 ! [D] Multiplied with calculated value to get Battery full
                       ! capacity
CAP_BATTERY_MAX_OFFSET 0 ; A-h ! [D] Added to get Battery full capacity

! CMP_STRUT_LEVER: Spring/damper lever movement as a function of jounce. Strut lever
! movement is a function of suspension jounce (COEFFICIENT or TABLE). Strut lever
! movement from the calculation can be adjusted with CMP_STRUT_LEVER_GAIN and
! CMP_STRUT_LEVER_OFFSET. Suspension jounce used in the calculation can be adjusted
! with JNC_SCALE_CMP_STRUT_LEVER and JNC_START_CMP_STRUT_LEVER. An inverse version of
! this function is used internally. The derivative of this function is used
! internally. This configurable function supports 2 datasets; if indices shown below
! are not used, e.g., (2), the current value of the index IAXLE is used to identify
! the dataset when reading data.

CMP_STRUT_LEVER_COEFFICIENT(1) 1.307 ! Strut lever movement per unit suspension
                                     ! jounce (mm/mm)
CMP_STRUT_LEVER_GAIN(1) 1 ! [D] Multiplied with calculated value to get strut lever
                          ! movement
CMP_STRUT_LEVER_OFFSET(1) 0 ; mm ! [D] Added (after gain) to get strut lever
                            ! movement
JNC_START_CMP_STRUT_LEVER(1) 0 ; mm ! [D] Subtracted from suspension jounce
JNC_SCALE_CMP_STRUT_LEVER(1) 1 ! [D] Divided into (suspension jounce -
                               ! JNC_START_CMP_STRUT_LEVER)

! Col 1 = suspension jounce (mm), col 2 = strut lever movement (mm)
CMP_STRUT_LEVER_TABLE(2) SPLINE ! spline interpolation and extrapolation
 -20, 0
 0, 10.7423
 20, 21.6048
 40, 32.5975
 60, 43.7315
 80, 55.0188
 100, 66.4723
 120, 78.106
 140, 89.9347
 160, 101.9743
 180, 114.2416
 200, 126.7543
ENDTABLE
CMP_STRUT_LEVER_GAIN(2) 1 ! [D] Multiplied with calculated value to get strut lever
                          ! movement
CMP_STRUT_LEVER_OFFSET(2) 0 ; mm ! [D] Added (after gain) to get strut lever
                            ! movement
JNC_START_CMP_STRUT_LEVER(2) 0 ; mm ! [D] Subtracted from suspension jounce
JNC_SCALE_CMP_STRUT_LEVER(2) 1 ! [D] Divided into (suspension jounce -
                               ! JNC_START_CMP_STRUT_LEVER)

! FBK_CON: Brake input force from rider. Brake input force is a function of time
! (CONSTANT, COEFFICIENT, or TABLE). Alternatively, a custom equation can be defined
! at runtime. Brake input force from the calculation can be adjusted with
! FBK_CON_GAIN and FBK_CON_OFFSET. Time used in the calculation can be adjusted with
! TSCALE_FBK_CON and TSTART_FBK_CON. This configurable function supports 2 datasets;
! if indices shown below are not used, e.g., (2), the current value of the index
! IAXLE is used to identify the dataset when reading data.

FBK_CON_CONSTANT(1) 0 ; N ! Brake input force
FBK_CON_OFFSET(1)   0 ; N ! [D] Added to get brake input force

FBK_CON_CONSTANT(2) 0 ; N ! Brake input force
FBK_CON_OFFSET(2)   0 ; N ! [D] Added to get brake input force

! FD: Suspension damper force as a function of compression rate. Damper force is a
! function of rate (CONSTANT, COEFFICIENT, or TABLE). Alternatively, a custom
! equation can be defined at runtime. Damper force from the calculation can be
! adjusted with FD_GAIN and FD_OFFSET. Rate used in the calculation can be adjusted
! with CMP_R_SCALE_FD and CMP_R_START_FD. This configurable function supports 2
! datasets; if indices shown below are not used, e.g., (2), the current value of the
! index IAXLE is used to identify the dataset when reading data.

FD_COEFFICIENT(1)   2 ! Damper force per unit rate (N/[mm/s])
FD_GAIN(1)          1 ! [D] Multiplied with calculated value to get damper force
FD_OFFSET(1)        0 ; N ! [D] Added (after gain) to get damper force
CMP_R_START_FD(1)   0 ; mm/s ! [D] Subtracted from rate
CMP_R_SCALE_FD(1)   1 ! [D] Divided into (rate - CMP_R_START_FD)

FD_COEFFICIENT(2)  10 ! Damper force per unit rate (N/[mm/s])
FD_GAIN(2)          1 ! [D] Multiplied with calculated value to get damper force
FD_OFFSET(2)        0 ; N ! [D] Added (after gain) to get damper force
CMP_R_START_FD(2)   0 ; mm/s ! [D] Subtracted from rate
CMP_R_SCALE_FD(2)   1 ! [D] Divided into (rate - CMP_R_START_FD)

! FS_COMP: Compression (upper) envelope of suspension spring force as a function of
! deflection. Spring force is a function of deflection (COEFFICIENT or TABLE). Spring
! force from the calculation can be adjusted with FS_COMP_GAIN and FS_COMP_OFFSET. An
! inverse version of this function is used internally. This configurable function
! supports 2 datasets; if indices shown below are not used, e.g., (2), the current
! value of the index IAXLE is used to identify the dataset when reading data.

! Col 1 = deflection (mm), col 2 = spring force (N)
FS_COMP_TABLE(1) LINEAR ! linear interpolation and extrapolation
 -90, -3042
 -80, -1042
 0, 958
 60, 2458
 70, 4458
ENDTABLE
FS_COMP_GAIN(1)     1 ! [D] Multiplied with calculated value to get spring force
FS_COMP_OFFSET(1)   0 ; N ! [D] Added (after gain) to get spring force

! Col 1 = deflection (mm), col 2 = spring force (N)
FS_COMP_TABLE(2) LINEAR ! linear interpolation and extrapolation
 -110, -6793
 -100, -2793
 0, 1207
 98, 5127
 104, 6207
 110, 11207
ENDTABLE
FS_COMP_GAIN(2)     1 ! [D] Multiplied with calculated value to get spring force
FS_COMP_OFFSET(2)   0 ; N ! [D] Added (after gain) to get spring force

! FS_EXT: Extension (lower) envelope of suspension spring force as a function of
! deflection. Spring force is a function of deflection (COEFFICIENT or TABLE). Spring
! force from the calculation can be adjusted with FS_EXT_GAIN and FS_EXT_OFFSET. An
! inverse version of this function is used internally. This configurable function
! supports 2 datasets; if indices shown below are not used, e.g., (2), the current
! value of the index IAXLE is used to identify the dataset when reading data.

! Col 1 = deflection (mm), col 2 = spring force (N)
FS_EXT_TABLE(1) LINEAR ! linear interpolation and extrapolation
 -90, -3092
 -80, -1092
 0, 908
 60, 2408
 70, 4408
ENDTABLE
FS_EXT_GAIN(1)      1 ! [D] Multiplied with calculated value to get spring force
FS_EXT_OFFSET(1)    0 ; N ! [D] Added (after gain) to get spring force

! Col 1 = deflection (mm), col 2 = spring force (N)
FS_EXT_TABLE(2) LINEAR ! linear interpolation and extrapolation
 -110, -6843
 -100, -2843
 0, 1157
 98, 5077
 104, 6157
 110, 11157
ENDTABLE
FS_EXT_GAIN(2)      1 ! [D] Multiplied with calculated value to get spring force
FS_EXT_OFFSET(2)    0 ; N ! [D] Added (after gain) to get spring force

! FX_AERO_SHAPING: Shaping function for X component of aerodynamic force. Shaping
! function is a function of aerodynamic slip angle (CONSTANT, COEFFICIENT, or TABLE).
! Alternatively, a custom equation can be defined at runtime. Shaping function from
! the calculation can be adjusted with FX_AERO_SHAPING_GAIN and
! FX_AERO_SHAPING_OFFSET. Aerodynamic slip angle used in the calculation can be
! adjusted with SLIP_SCALE_FX_AERO and SLIP_START_FX_AERO.

FX_AERO_SHAPING_CONSTANT 0.52 ; - ! Shaping function
FX_AERO_SHAPING_GAIN 1 ! [D] Multiplied with calculated value to get shaping
                       ! function
FX_AERO_SHAPING_OFFSET 0 ; - ! [D] Added to get shaping function

! FY_AERO_SHAPING: Shaping function for Y component of aerodynamic force. Shaping
! function is a function of aerodynamic slip angle (CONSTANT, COEFFICIENT, or TABLE).
! Alternatively, a custom equation can be defined at runtime. Shaping function from
! the calculation can be adjusted with FY_AERO_SHAPING_GAIN and
! FY_AERO_SHAPING_OFFSET. Aerodynamic slip angle used in the calculation can be
! adjusted with SLIP_SCALE_FY_AERO and SLIP_START_FY_AERO.

FY_AERO_SHAPING_CONSTANT 0 ; - ! Shaping function
FY_AERO_SHAPING_OFFSET 0 ; - ! [D] Added to get shaping function

! FZ_AERO_SHAPING: Shaping function for Z component of aerodynamic force. Shaping
! function is a function of aerodynamic slip angle (CONSTANT, COEFFICIENT, or TABLE).
! Alternatively, a custom equation can be defined at runtime. Shaping function from
! the calculation can be adjusted with FZ_AERO_SHAPING_GAIN and
! FZ_AERO_SHAPING_OFFSET. Aerodynamic slip angle used in the calculation can be
! adjusted with SLIP_SCALE_FZ_AERO and SLIP_START_FZ_AERO.

FZ_AERO_SHAPING_CONSTANT 0.085 ; - ! Shaping function
FZ_AERO_SHAPING_GAIN 1 ! [D] Multiplied with calculated value to get shaping
                       ! function
FZ_AERO_SHAPING_OFFSET 0 ; - ! [D] Added to get shaping function

! FZ_TIRE: Tire vertical force as function of tire compression and inclination.
! Vertical force can be a nonlinear CARPET function of tire inclination and tire
! compression or a function of tire compression (CONSTANT, COEFFICIENT, or TABLE).
! Vertical force from the calculation can be adjusted with FZ_TIRE_GAIN and
! FZ_TIRE_OFFSET. Tire compression used in the calculation can be adjusted with
! CMP_SCALE_FZ_TIRE and CMP_START_FZ_TIRE. Tire inclination used in the calculation
! can be adjusted with GAM_SCALE_FZ_TIRE and GAM_START_FZ_TIRE. An inverse version of
! this function is used internally. This configurable function supports 2 datasets;
! if indices shown below are not used, e.g., (2), the current value of the index
! IAXLE is used to identify the dataset when reading data.

FZ_TIRE_COEFFICIENT(1) 130 ! Vertical force per unit tire compression (N/mm)
FZ_TIRE_GAIN(1)     1 ! [D] Multiplied with calculated value to get vertical force
FZ_TIRE_OFFSET(1)   0 ; N ! [D] Added (after gain) to get vertical force
CMP_START_FZ_TIRE(1) 0 ; mm ! [D] Subtracted from tire compression
CMP_SCALE_FZ_TIRE(1) 1 ! [D] Divided into (tire compression - CMP_START_FZ_TIRE)

FZ_TIRE_COEFFICIENT(2) 141 ! Vertical force per unit tire compression (N/mm)
FZ_TIRE_GAIN(2)     1 ! [D] Multiplied with calculated value to get vertical force
FZ_TIRE_OFFSET(2)   0 ; N ! [D] Added (after gain) to get vertical force
CMP_START_FZ_TIRE(2) 0 ; mm ! [D] Subtracted from tire compression
CMP_SCALE_FZ_TIRE(2) 1 ! [D] Divided into (tire compression - CMP_START_FZ_TIRE)

! F_AXLE_VX: Axle force as a function of wheel longitudinal displacement rate and
! suspension compression. Axle force can be a nonlinear CARPET function of suspension
! compression and x disp. rate or a function of x disp. rate (CONSTANT, COEFFICIENT,
! or TABLE) multiplied by a function F_AXLE_VX_CMP of suspension compression
! (CONSTANT, COEFFICIENT, or TABLE). Alternatively, a custom equation can be defined
! at runtime. Axle force from the calculation can be adjusted with F_AXLE_VX_GAIN and
! F_AXLE_VX_OFFSET. X disp. rate used in the calculation can be adjusted with
! VX_SCALE_F_AXLE_VX and VX_START_F_AXLE_VX. Suspension compression used in the
! calculation can be adjusted with CMP_SCALE_F_AXLE_VX and CMP_START_F_AXLE_VX.

! Row 1 has "0" (place holder) followed by 3 values of suspension compression (mm).
! Other rows have x disp. rate (mm/s) followed by 3 values of axle force (N).
F_AXLE_VX_CARPET 2D_LINEAR
 0, -200, 0, 200
 -1, -0.8, -1, -1.2
 0, 0, 0, 0
 1, 0.8, 1, 1.2
ENDTABLE
F_AXLE_VX_GAIN      1 ! [D] Multiplied with calculated value to get axle force
F_AXLE_VX_OFFSET    0 ; N ! [D] Added (after gain) to get axle force
VX_START_F_AXLE_VX  0 ; mm/s ! [D] Subtracted from x disp. rate
VX_SCALE_F_AXLE_VX  1 ! [D] Divided into (x disp. rate - VX_START_F_AXLE_VX)
CMP_START_F_AXLE_VX 0 ; mm ! [D] Subtracted from suspension compression
CMP_SCALE_F_AXLE_VX 1 ! [D] Divided into (suspension compression -
                      ! CMP_START_F_AXLE_VX)

! F_AXLE_X: Axle force as a function of wheel longitudinal displacement (X) and
! suspension compression. Axle force can be a nonlinear CARPET function of suspension
! compression and x displacement or a function of x displacement (CONSTANT,
! COEFFICIENT, or TABLE) multiplied by a function F_AXLE_X_CMP of suspension
! compression (CONSTANT, COEFFICIENT, or TABLE). Alternatively, a custom equation can
! be defined at runtime. Axle force from the calculation can be adjusted with
! F_AXLE_X_GAIN and F_AXLE_X_OFFSET. X displacement used in the calculation can be
! adjusted with X_SCALE_F_AXLE_X and X_START_F_AXLE_X. Suspension compression used in
! the calculation can be adjusted with CMP_SCALE_F_AXLE_X and CMP_START_F_AXLE_X.

! Row 1 has "0" (place holder) followed by 3 values of suspension compression (mm).
! Other rows have x displacement (mm) followed by 3 values of axle force (N).
F_AXLE_X_CARPET 2D_LINEAR
 0, -200, 0, 200
 -1, -250, -274, -298
 0, 0, 0, 0
 1, 250, 274, 298
ENDTABLE
F_AXLE_X_GAIN       1 ! [D] Multiplied with calculated value to get axle force
F_AXLE_X_OFFSET     0 ; N ! [D] Added (after gain) to get axle force
X_START_F_AXLE_X    0 ; mm ! [D] Subtracted from x displacement
X_SCALE_F_AXLE_X    1 ! [D] Divided into (x displacement - X_START_F_AXLE_X)
CMP_START_F_AXLE_X  0 ; mm ! [D] Subtracted from suspension compression
CMP_SCALE_F_AXLE_X  1 ! [D] Divided into (suspension compression -
                      ! CMP_START_F_AXLE_X)

! LTARG: Target lateral offset (+ -> left, - -> right). This offset is combined with
! a reference path to produce a modified path for steering control, moving objects,
! lane definition, etc. Lateral offset is a function of station (CONSTANT,
! COEFFICIENT, or TABLE). Lateral offset from the calculation can be adjusted with
! LTARG_GAIN and LTARG_OFFSET. Station used in the calculation can be adjusted with
! SSCALE_LTARG and SSTART_LTARG. The derivative of this function is used internally.
! This configurable function supports 500 datasets; if indices shown below are not
! used, e.g., (2), the current value of the index ILTARG is used to identify the
! dataset when reading data.

LTARG_ID(1)         1  ! No Offset @  Variable Preview Time
LTARG_CONSTANT(1)   0 ; m ! Lateral offset
LTARG_OFFSET(1)     0 ; m ! [D] Added to get lateral offset

! L_RELAX_X: Tire longitudinal relaxation length as a function of vertical load (Fz)
! and lagged slip ratio (Kappa). L_Relax_X can be a nonlinear CARPET function of Fz
! and Lagged Kappa or a function of Lagged Kappa (CONSTANT or TABLE) combined with a
! function L_RELAX_X_FZ of Fz (CONSTANT, COEFFICIENT, or TABLE). Alternatively, a
! custom equation can be defined at runtime. L_Relax_X from the calculation can be
! adjusted with L_RELAX_X_GAIN and L_RELAX_X_OFFSET. Lagged Kappa used in the
! calculation can be adjusted with LAGGED_KAPPA_SCALE_L_RELAX_X. Fz used in the
! calculation can be adjusted with FZ_SCALE_L_RELAX_X. This configurable function
! supports 2 datasets; if indices shown below are not used, e.g., (2), the current
! value of the index IAXLE is used to identify the dataset when reading data.

L_RELAX_X_CONSTANT(1) 25 ; mm ! L_Relax_X component due to Lagged Kappa
L_RELAX_X_GAIN(1)   1 ! [D] Multiplied with calculated value to get L_Relax_X
L_RELAX_X_OFFSET(1) 0 ; mm ! [D] Added to get L_Relax_X
L_RELAX_X_COMBINE(1) MULTIPLY ! [D] How to combine the two components
L_RELAX_X_FZ_CONSTANT(1) 1 ; - ! [D] L_Relax_X component due to Fz

L_RELAX_X_CONSTANT(2) 25 ; mm ! L_Relax_X component due to Lagged Kappa
L_RELAX_X_GAIN(2)   1 ! [D] Multiplied with calculated value to get L_Relax_X
L_RELAX_X_OFFSET(2) 0 ; mm ! [D] Added to get L_Relax_X
L_RELAX_X_COMBINE(2) MULTIPLY ! [D] How to combine the two components
L_RELAX_X_FZ_CONSTANT(2) 1 ; - ! [D] L_Relax_X component due to Fz

! L_RELAX_Y: Tire lateral relaxation length as a function of vertical load (Fz) and
! lagged slip angle (Alpha). L_Relax_Y can be a nonlinear CARPET function of Fz and
! Lagged Alpha or a function of Lagged Alpha (CONSTANT or TABLE) combined with a
! function L_RELAX_Y_FZ of Fz (CONSTANT, COEFFICIENT, or TABLE). Alternatively, a
! custom equation can be defined at runtime. L_Relax_Y from the calculation can be
! adjusted with L_RELAX_Y_GAIN and L_RELAX_Y_OFFSET. Lagged Alpha used in the
! calculation can be adjusted with LAGGED_ALPHA_SCALE_L_RELAX_Y. Fz used in the
! calculation can be adjusted with FZ_SCALE_L_RELAX_Y. This configurable function
! supports 2 datasets; if indices shown below are not used, e.g., (2), the current
! value of the index IAXLE is used to identify the dataset when reading data.

L_RELAX_Y_CONSTANT(1) 200 ; mm ! L_Relax_Y component due to Lagged Alpha
L_RELAX_Y_GAIN(1)   1 ! [D] Multiplied with calculated value to get L_Relax_Y
L_RELAX_Y_OFFSET(1) 0 ; mm ! [D] Added to get L_Relax_Y
L_RELAX_Y_COMBINE(1) MULTIPLY ! [D] How to combine the two components
L_RELAX_Y_FZ_CONSTANT(1) 1 ; - ! [D] L_Relax_Y component due to Fz

L_RELAX_Y_CONSTANT(2) 200 ; mm ! L_Relax_Y component due to Lagged Alpha
L_RELAX_Y_GAIN(2)   1 ! [D] Multiplied with calculated value to get L_Relax_Y
L_RELAX_Y_OFFSET(2) 0 ; mm ! [D] Added to get L_Relax_Y
L_RELAX_Y_COMBINE(2) MULTIPLY ! [D] How to combine the two components
L_RELAX_Y_FZ_CONSTANT(2) 1 ; - ! [D] L_Relax_Y component due to Fz

! MMOTOR_MAX: Motor maximum torque. Motor full torque is a function of motor speed
! (CONSTANT, COEFFICIENT, or TABLE). Alternatively, a custom equation can be defined
! at runtime. Motor full torque from the calculation can be adjusted with
! MMOTOR_MAX_GAIN and MMOTOR_MAX_OFFSET. Motor speed used in the calculation can be
! adjusted with SPIN_SCALE_M_MOTOR_MAX and SPIN_START_M_MOTOR_MAX.

! Col 1 = motor speed (rpm), col 2 = Motor full torque (N-m)
MMOTOR_MAX_TABLE LINEAR_FLAT ! linear interpolation, flat-line extrapolation
 0, 200
 762.5, 200
 1525, 189.79
 2287.5, 126.03
 3050, 94.341
 3812.5, 75.354
 4575, 62.721
 5337.5, 53.716
 6100, 47.026
 6862.5, 42.448
 9150, 31.279
ENDTABLE
MMOTOR_MAX_GAIN 1.525 ! Multiplied with calculated value to get Motor full torque
MMOTOR_MAX_OFFSET   0 ; N-m ! [D] Added (after gain) to get Motor full torque
SPIN_START_M_MOTOR_MAX 0 ; rpm ! [D] Subtracted from motor speed
SPIN_SCALE_M_MOTOR_MAX 0.6557377049 ! Divided into (motor speed -
                                    ! SPIN_START_M_MOTOR_MAX)

! MU_ROAD: Tire/road friction coefficient (MU) for a road surface. Use MU = -1 for
! original tire data (no scaling). MU can be a nonlinear CARPET function of lateral
! position and station or a function of station (CONSTANT or TABLE) combined with a
! function MU_ROAD_L of lateral position (CONSTANT or TABLE). Alternatively, a custom
! equation can be defined at runtime. MU from the calculation can be adjusted with
! MU_ROAD_GAIN and MU_ROAD_OFFSET. Station used in the calculation can be adjusted
! with SSCALE_MU_ROAD and SSTART_MU_ROAD. Lateral position used in the calculation
! can be adjusted with L_SCALE_MU_ROAD and L_START_MU_ROAD. This configurable
! function supports 200 datasets; if indices shown below are not used, e.g., (2), the
! current value of the index IROAD is used to identify the dataset when reading data.

! Row 1 has "0" (place holder) followed by 2 values of lateral position (m). Other
! rows have station (m) followed by 2 values of MU (-).
MU_ROAD_CARPET(1) 2D_LINEAR
 0, 0, 1
 0, 1, 1
 1, 1, 1
ENDTABLE
MU_ROAD_GAIN(1)     1 ! [D] Multiplied with calculated value to get MU
MU_ROAD_OFFSET(1)   0 ; - ! [D] Added (after gain) to get MU
SSTART_MU_ROAD(1)   0 ; m ! [D] Subtracted from station
SSCALE_MU_ROAD(1)   1 ! [D] Divided into (station - SSTART_MU_ROAD)
L_START_MU_ROAD(1)  0 ; m ! [D] Subtracted from lateral position
L_SCALE_MU_ROAD(1)  1 ! [D] Divided into (lateral position - L_START_MU_ROAD)

! MX_AERO_SHAPING: Shaping function for X component of aerodynamic moment. Shaping
! function is a function of aerodynamic slip angle (CONSTANT, COEFFICIENT, or TABLE).
! Alternatively, a custom equation can be defined at runtime. Shaping function from
! the calculation can be adjusted with MX_AERO_SHAPING_GAIN and
! MX_AERO_SHAPING_OFFSET. Aerodynamic slip angle used in the calculation can be
! adjusted with SLIP_SCALE_MX_AERO and SLIP_START_MX_AERO.

MX_AERO_SHAPING_CONSTANT 0 ; - ! Shaping function
MX_AERO_SHAPING_OFFSET 0 ; - ! [D] Added to get shaping function

! MY_AERO_SHAPING: Shaping function for Y component of aerodynamic moment. Shaping
! function is a function of aerodynamic slip angle (CONSTANT, COEFFICIENT, or TABLE).
! Alternatively, a custom equation can be defined at runtime. Shaping function from
! the calculation can be adjusted with MY_AERO_SHAPING_GAIN and
! MY_AERO_SHAPING_OFFSET. Aerodynamic slip angle used in the calculation can be
! adjusted with SLIP_SCALE_MY_AERO and SLIP_START_MY_AERO.

MY_AERO_SHAPING_CONSTANT 0.205 ; - ! Shaping function
MY_AERO_SHAPING_GAIN 1 ! [D] Multiplied with calculated value to get shaping
                       ! function
MY_AERO_SHAPING_OFFSET 0 ; - ! [D] Added to get shaping function

! MZ_AERO_SHAPING: Shaping function for Z component of aerodynamic moment. Shaping
! function is a function of aerodynamic slip angle (CONSTANT, COEFFICIENT, or TABLE).
! Alternatively, a custom equation can be defined at runtime. Shaping function from
! the calculation can be adjusted with MZ_AERO_SHAPING_GAIN and
! MZ_AERO_SHAPING_OFFSET. Aerodynamic slip angle used in the calculation can be
! adjusted with SLIP_SCALE_MZ_AERO and SLIP_START_MZ_AERO.

MZ_AERO_SHAPING_CONSTANT 0 ; - ! Shaping function
MZ_AERO_SHAPING_OFFSET 0 ; - ! [D] Added to get shaping function

! MZ_STR: Steering system torque as a function of steer angle. Steer torque is a
! function of steer angle (CONSTANT, COEFFICIENT, or TABLE). Alternatively, a custom
! equation can be defined at runtime. Steer torque from the calculation can be
! adjusted with MZ_STR_GAIN and MZ_STR_OFFSET. Steer angle used in the calculation
! can be adjusted with STR_SCALE_MZ_STR and STR_START_MZ_STR.

! Col 1 = steer angle (deg), col 2 = steer torque (N-m)
MZ_STR_TABLE LINEAR ! linear interpolation and extrapolation
 -31, -100
 -30, 0
 30, 0
 31, 100
ENDTABLE
MZ_STR_GAIN         1 ! [D] Multiplied with calculated value to get steer torque
MZ_STR_OFFSET       0 ; N-m ! [D] Added (after gain) to get steer torque
STR_START_MZ_STR    0 ; deg ! [D] Subtracted from steer angle
STR_SCALE_MZ_STR    1 ! [D] Divided into (steer angle - STR_START_MZ_STR)

! M_SHAFT_AV: Driveshaft moment as a function of torsional speed. Driveshaft moment
! is a function of torsional speed (CONSTANT, COEFFICIENT, or TABLE). Alternatively,
! a custom equation can be defined at runtime. Driveshaft moment from the calculation
! can be adjusted with M_SHAFT_AV_GAIN and M_SHAFT_AV_OFFSET. Torsional speed used in
! the calculation can be adjusted with AV_SCALE_M_SHAFT and AV_START_M_SHAFT.

M_SHAFT_AV_COEFFICIENT 0.42 ! Driveshaft moment per unit torsional speed
                            ! (N-m/[deg/s])
M_SHAFT_AV_GAIN     1 ! [D] Multiplied with calculated value to get driveshaft
                      ! moment
M_SHAFT_AV_OFFSET   0 ; N-m ! [D] Added (after gain) to get driveshaft moment
AV_START_M_SHAFT    0 ; deg/s ! [D] Subtracted from torsional speed
AV_SCALE_M_SHAFT    1 ! [D] Divided into (torsional speed - AV_START_M_SHAFT)

! M_SHAFT_ROT: Driveshaft moment as a function of torsional deflection. Driveshaft
! moment is a function of torsional deflection (CONSTANT, COEFFICIENT, or TABLE).
! Alternatively, a custom equation can be defined at runtime. Driveshaft moment from
! the calculation can be adjusted with M_SHAFT_ROT_GAIN and M_SHAFT_ROT_OFFSET.
! Torsional deflection used in the calculation can be adjusted with ROT_SCALE_M_SHAFT
! and ROT_START_M_SHAFT.

M_SHAFT_ROT_COEFFICIENT 8.4 ! Driveshaft moment per unit torsional deflection
                            ! (N-m/deg)
M_SHAFT_ROT_GAIN    1 ! [D] Multiplied with calculated value to get driveshaft
                      ! moment
M_SHAFT_ROT_OFFSET  0 ; N-m ! [D] Added (after gain) to get driveshaft moment
ROT_START_M_SHAFT   0 ; deg ! [D] Subtracted from torsional deflection
ROT_SCALE_M_SHAFT   1 ! [D] Divided into (torsional deflection - ROT_START_M_SHAFT)

! PBK_DL: Brake delivery pressure as a function of M/C pressure and dynamic wheel
! load (at ground). Delivery pressure can be a nonlinear CARPET function of dynamic
! wheel load and master cylinder pressure or a function of master cylinder pressure
! (CONSTANT, COEFFICIENT, or TABLE) combined with a function PBK_DL_FZ of dynamic
! wheel load (CONSTANT, COEFFICIENT, or TABLE). Alternatively, a custom equation can
! be defined at runtime. Delivery pressure from the calculation can be adjusted with
! PBK_DL_GAIN and PBK_DL_OFFSET. Master cylinder pressure used in the calculation can
! be adjusted with PBK_CON_SCALE_PBK_DL and PBK_CON_START_PBK_DL. Dynamic wheel load
! used in the calculation can be adjusted with FZ_SCALE_PBK_DL and FZ_START_PBK_DL.
! This configurable function supports 2 datasets; if indices shown below are not
! used, e.g., (2), the current value of the index IAXLE is used to identify the
! dataset when reading data.

PBK_DL_COEFFICIENT(1) 1 ! Delivery pressure per unit master cylinder pressure
                        ! (MPa/MPa)
PBK_DL_GAIN(1)      1 ! [D] Multiplied with calculated value to get delivery
                      ! pressure
PBK_DL_OFFSET(1)    0 ; MPa ! [D] Added (after gain) to get delivery pressure
PBK_CON_START_PBK_DL(1) 0 ; MPa ! [D] Subtracted from master cylinder pressure
PBK_CON_SCALE_PBK_DL(1) 1 ! [D] Divided into (master cylinder pressure -
                          ! PBK_CON_START_PBK_DL)
PBK_DL_COMBINE(1) ADD ! How to combine the two components
SET_UNITS PBK_DL_FZ_TABLE(1) MPa ;
PBK_DL_FZ_CONSTANT(1) 0 ; MPa ! Delivery pressure component due to dynamic wheel
                        ! load

PBK_DL_COEFFICIENT(2) 0 ! Delivery pressure per unit master cylinder pressure
                        ! (MPa/MPa)
PBK_DL_GAIN(2)      1 ! [D] Multiplied with calculated value to get delivery
                      ! pressure
PBK_DL_OFFSET(2)    0 ; MPa ! [D] Added (after gain) to get delivery pressure
PBK_CON_START_PBK_DL(2) 0 ; MPa ! [D] Subtracted from master cylinder pressure
PBK_CON_SCALE_PBK_DL(2) 1 ! [D] Divided into (master cylinder pressure -
                          ! PBK_CON_START_PBK_DL)
PBK_DL_COMBINE(2) ADD ! How to combine the two components
SET_UNITS PBK_DL_FZ_TABLE(2) MPa ;
PBK_DL_FZ_CONSTANT(2) 0 ; MPa ! Delivery pressure component due to dynamic wheel
                        ! load

! PWR_DRV_THROTTLE: Driving power demanded by throttle pedal. Driving power is a
! function of Throttle pedal position (CONSTANT, COEFFICIENT, or TABLE).
! Alternatively, a custom equation can be defined at runtime. Driving power from the
! calculation can be adjusted with PWR_DRV_THROTTLE_GAIN and PWR_DRV_THROTTLE_OFFSET.
! Throttle pedal position used in the calculation can be adjusted with
! SPIN_SCALE_PWR_DRV_THRT and SPIN_START_PWR_DRV_THRT. An inverse version of this
! function is used internally.

PWR_DRV_THROTTLE_COEFFICIENT 90 ! Driving power per unit Throttle pedal position
                                ! (kW/-)
PWR_DRV_THROTTLE_GAIN 1 ! [D] Multiplied with calculated value to get Driving power
PWR_DRV_THROTTLE_OFFSET 0 ; kW ! [D] Added (after gain) to get Driving power
SPIN_START_PWR_DRV_THRT 0 ; - ! [D] Subtracted from Throttle pedal position
SPIN_SCALE_PWR_DRV_THRT 1 ! [D] Divided into (Throttle pedal position -
                          ! SPIN_START_PWR_DRV_THRT)

! RIDER_BODY_LEAN: Rider body lean angle relative to main frame. Lean angle can be a
! nonlinear CARPET function of Station and time or a function of time (CONSTANT,
! COEFFICIENT, or TABLE) combined with a function RIDER_BODY_LEAN_S of Station
! (CONSTANT, COEFFICIENT, or TABLE). Alternatively, a custom equation can be defined
! at runtime. Lean angle from the calculation can be adjusted with
! RIDER_BODY_LEAN_GAIN and RIDER_BODY_LEAN_OFFSET. Time used in the calculation can
! be adjusted with TSCALE_RIDER_BODY_LEAN and TSTART_RIDER_BODY_LEAN. Station used in
! the calculation can be adjusted with SSCALE_RIDER_BODY_LEAN and
! SSTART_RIDER_BODY_LEAN.

RIDER_BODY_LEAN_CONSTANT 0 ; deg ! [D] Lean angle component due to time
RIDER_BODY_LEAN_GAIN 1 ! [D] Multiplied with calculated value to get lean angle
RIDER_BODY_LEAN_OFFSET 0 ; deg ! [D] Added to get lean angle
RIDER_BODY_LEAN_COMBINE MULTIPLY ! [D] How to combine the two components
RIDER_BODY_LEAN_S_CONSTANT 1 ; - ! [D] Lean angle component due to Station

! RIDER_BODY_Y: Rider body lateral position relative to seat. Lateral position can
! be a nonlinear CARPET function of Station and time or a function of time (CONSTANT,
! COEFFICIENT, or TABLE) combined with a function RIDER_BODY_Y_S of Station
! (CONSTANT, COEFFICIENT, or TABLE). Alternatively, a custom equation can be defined
! at runtime. Lateral position from the calculation can be adjusted with
! RIDER_BODY_Y_GAIN and RIDER_BODY_Y_OFFSET. Time used in the calculation can be
! adjusted with TSCALE_RIDER_BODY_Y and TSTART_RIDER_BODY_Y.

RIDER_BODY_Y_CONSTANT 0 ; mm ! [D] Lateral position component due to time
RIDER_BODY_Y_GAIN   1 ! [D] Multiplied with calculated value to get lateral position
RIDER_BODY_Y_OFFSET 0 ; mm ! [D] Added to get lateral position
RIDER_BODY_Y_COMBINE MULTIPLY ! [D] How to combine the two components
RIDER_BODY_Y_S_CONSTANT 1 ; - ! [D] Lateral position component due to Station

! RIDER_BODY_Z: Rider body vertical movement (Z) as a function of lateral movement
! (Y). Z movement is a function of y movement (CONSTANT, COEFFICIENT, or TABLE). Z
! movement from the calculation can be adjusted with RIDER_BODY_Z_GAIN and
! RIDER_BODY_Z_OFFSET. Y movement used in the calculation can be adjusted with
! Y_SCALE_RIDER_BODY_Z and Y_START_RIDER_BODY_Z. The derivative of this function is
! used internally.

! [D] Col 1 = y movement (mm), col 2 = z movement (mm)
RIDER_BODY_Z_TABLE SPLINE ! spline interpolation and extrapolation
 -200, -100
 0, 0
 200, -100
ENDTABLE
RIDER_BODY_Z_GAIN   1 ! [D] Multiplied with calculated value to get z movement
RIDER_BODY_Z_OFFSET 0 ; mm ! [D] Added (after gain) to get z movement
Y_START_RIDER_BODY_Z 0 ; mm ! [D] Subtracted from y movement
Y_SCALE_RIDER_BODY_Z 1 ! [D] Divided into (y movement - Y_START_RIDER_BODY_Z)

! RIDER_LEGS_CG_Y: Rider legs CG lateral movement (Y) as a function of rider body
! lateral movement (Y). Legs CG y movement is a function of body y movement
! (CONSTANT, COEFFICIENT, or TABLE). Legs CG y movement from the calculation can be
! adjusted with RIDER_LEGS_CG_Y_GAIN and RIDER_LEGS_CG_Y_OFFSET. Body y movement used
! in the calculation can be adjusted with Y_SCALE_RIDER_LEGS_CG_Y and
! Y_START_RIDER_LEGS_CG_Y. The derivative of this function is used internally.

! [D] Col 1 = body y movement (mm), col 2 = legs CG y movement (mm)
RIDER_LEGS_CG_Y_TABLE SPLINE ! spline interpolation and extrapolation
 -1, -0.5
 0, 0
 1, 0.5
ENDTABLE
RIDER_LEGS_CG_Y_GAIN 1 ! [D] Multiplied with calculated value to get legs CG y
                       ! movement
RIDER_LEGS_CG_Y_OFFSET 0 ; mm ! [D] Added (after gain) to get legs CG y movement
Y_START_RIDER_LEGS_CG_Y 0 ; mm ! [D] Subtracted from body y movement
Y_SCALE_RIDER_LEGS_CG_Y 1 ! [D] Divided into (body y movement -
                          ! Y_START_RIDER_LEGS_CG_Y)

! RIDER_LEGS_CG_Z: Rider legs CG vertical movement (Z) as a function of rider body
! lateral movement (Y). Legs CG z movement is a function of body y movement
! (CONSTANT, COEFFICIENT, or TABLE). Legs CG z movement from the calculation can be
! adjusted with RIDER_LEGS_CG_Z_GAIN and RIDER_LEGS_CG_Z_OFFSET. Body y movement used
! in the calculation can be adjusted with Y_SCALE_RIDER_LEGS_CG_Z and
! Y_START_RIDER_LEGS_CG_Z. The derivative of this function is used internally.

! [D] Col 1 = body y movement (mm), col 2 = legs CG z movement (mm)
RIDER_LEGS_CG_Z_TABLE SPLINE ! spline interpolation and extrapolation
 -200, -50
 0, 0
 200, -50
ENDTABLE
RIDER_LEGS_CG_Z_GAIN 1 ! [D] Multiplied with calculated value to get legs CG z
                       ! movement
RIDER_LEGS_CG_Z_OFFSET 0 ; mm ! [D] Added (after gain) to get legs CG z movement
Y_START_RIDER_LEGS_CG_Z 0 ; mm ! [D] Subtracted from body y movement
Y_SCALE_RIDER_LEGS_CG_Z 1 ! [D] Divided into (body y movement -
                          ! Y_START_RIDER_LEGS_CG_Z)

! ROAD_NEW_ID: Left/right boundary: 0 -> no boundary, -1 stop when L reaches
! boundary, > 0 ID of adjacent road. ID is a function of S (CONSTANT, COEFFICIENT, or
! TABLE). Alternatively, a custom equation can be defined at runtime. ID from the
! calculation can be adjusted with ROAD_NEW_ID_GAIN and ROAD_NEW_ID_OFFSET. S used in
! the calculation can be adjusted with SSCALE_ROAD_NEW_ID and SSTART_ROAD_NEW_ID.
! This configurable function supports 400 datasets; if indices shown below are not
! used, e.g., (1,2), the current values of the indices IROAD and ISIDE are used to
! identify the dataset when reading data.

ROAD_NEW_ID_CONSTANT(1,1) 0 ; - ! [D] ID, Road 1, left side boundary
ROAD_NEW_ID_OFFSET(1,1) 0 ; - ! [D] Added to get ID

ROAD_NEW_ID_CONSTANT(1,2) 0 ; - ! [D] ID, Road 1, right side boundary
ROAD_NEW_ID_OFFSET(1,2) 0 ; - ! [D] Added to get ID

! ROAD_ZS: Road elevation component related only to road station S. Elevation is a
! function of station (CONSTANT, COEFFICIENT, or TABLE). Elevation from the
! calculation can be adjusted with ROAD_ZS_GAIN and ROAD_ZS_OFFSET. Station used in
! the calculation can be adjusted with SSCALE_ROAD_ZS and SSTART_ROAD_ZS. The
! derivative of this function is used internally. This configurable function supports
! 200 datasets; if indices shown below are not used, e.g., (2), the current value of
! the index IROAD is used to identify the dataset when reading data.

ROAD_ZS_CONSTANT(1) 0 ; m ! [D] Elevation
ROAD_ZS_OFFSET(1)   0 ; m ! [D] Added to get elevation

! RR_SURF: Tire/road rolling resistance surface-effect coefficient. RR_SURF can be a
! nonlinear CARPET function of lateral position and station or a function of station
! (CONSTANT or TABLE) combined with a function RR_SURF_L of lateral position
! (CONSTANT or TABLE). Alternatively, a custom equation can be defined at runtime.
! RR_SURF from the calculation can be adjusted with RR_SURF_GAIN and RR_SURF_OFFSET.
! Station used in the calculation can be adjusted with SSCALE_RR_SURF and
! SSTART_RR_SURF. Lateral position used in the calculation can be adjusted with
! L_SCALE_RR_SURF and L_START_RR_SURF. This configurable function supports 200
! datasets; if indices shown below are not used, e.g., (2), the current value of the
! index IROAD is used to identify the dataset when reading data.

RR_SURF_CONSTANT(1) 1 ; - ! RR_SURF component due to station
RR_SURF_GAIN(1)     1 ! [D] Multiplied with calculated value to get RR_SURF
RR_SURF_OFFSET(1)   0 ; - ! [D] Added to get RR_SURF
RR_SURF_COMBINE(1) MULTIPLY ! [D] How to combine the two components
RR_SURF_L_CONSTANT(1) 1 ; - ! [D] RR_SURF component due to lateral position

! R_CHRG_BATTERY: Battery resistance being charged. Battery resistance can be a
! nonlinear CARPET function of Temperature and Battery level state of charge or a
! function of Battery level state of charge (CONSTANT, COEFFICIENT, or TABLE)
! multiplied by a function R_CHRG_BATTERY_TEMP of Temperature (CONSTANT, COEFFICIENT,
! or TABLE). Alternatively, a custom equation can be defined at runtime. Battery
! resistance from the calculation can be adjusted with R_CHRG_BATTERY_GAIN and
! R_CHRG_BATTERY_OFFSET. Battery level state of charge used in the calculation can be
! adjusted with SOC_SCALE_R_CHRG_BATTERY and SOC_START_R_CHRG_BATTERY. Temperature
! used in the calculation can be adjusted with TEMP_SCALE_R_CHRG_BATTERY and
! TEMP_START_R_CHRG_BATTERY.

! Row 1 has "0" (place holder) followed by 3 values of Temperature (C). Other rows
! have Battery level state of charge (-) followed by 3 values of Battery resistance
! (V2/W).
R_CHRG_BATTERY_CARPET 2D_SPLINE
 0, 0, 25, 45
 0, 0.03525, 0.017625, 0.017625
 0.2, 0.03075, 0.015375, 0.015375
 0.6, 0.0297, 0.01485, 0.01485
 1, 0.0306, 0.0153, 0.0153
ENDTABLE
R_CHRG_BATTERY_GAIN 1 ! [D] Multiplied with calculated value to get Battery
                      ! resistance
R_CHRG_BATTERY_OFFSET 0 ; V2/W ! [D] Added (after gain) to get Battery resistance
SOC_START_R_CHRG_BATTERY 0 ; - ! [D] Subtracted from Battery level state of charge
SOC_SCALE_R_CHRG_BATTERY 1 ! [D] Divided into (Battery level state of charge -
                           ! SOC_START_R_CHRG_BATTERY)
TEMP_START_R_CHRG_BATTERY 0 ; C ! [D] Subtracted from Temperature
TEMP_SCALE_R_CHRG_BATTERY 1 ! [D] Divided into (Temperature -
                            ! TEMP_START_R_CHRG_BATTERY)

! R_DIS_BATTERY: Battery resistance being discharged. Battery resistance can be a
! nonlinear CARPET function of Temperature and Battery level state of charge or a
! function of Battery level state of charge (CONSTANT, COEFFICIENT, or TABLE)
! multiplied by a function R_DIS_BATTERY_TEMP of Temperature (CONSTANT, COEFFICIENT,
! or TABLE). Alternatively, a custom equation can be defined at runtime. Battery
! resistance from the calculation can be adjusted with R_DIS_BATTERY_GAIN and
! R_DIS_BATTERY_OFFSET. Battery level state of charge used in the calculation can be
! adjusted with SOC_SCALE_R_DIS_BATTERY and SOC_START_R_DIS_BATTERY. Temperature used
! in the calculation can be adjusted with TEMP_SCALE_R_DIS_BATTERY and
! TEMP_START_R_DIS_BATTERY.

! Row 1 has "0" (place holder) followed by 3 values of Temperature (C). Other rows
! have Battery level state of charge (-) followed by 3 values of Battery resistance
! (V2/W).
R_DIS_BATTERY_CARPET 2D_SPLINE
 0, 0, 25, 45
 0, 0.050267, 0.025133, 0.025133
 0.2, 0.04, 0.02, 0.02
 0.6, 0.035867, 0.017933, 0.017933
 1, 0.0416, 0.0208, 0.0208
ENDTABLE
R_DIS_BATTERY_GAIN  1 ! [D] Multiplied with calculated value to get Battery
                      ! resistance
R_DIS_BATTERY_OFFSET 0 ; V2/W ! [D] Added (after gain) to get Battery resistance
SOC_START_R_DIS_BATTERY 0 ; - ! [D] Subtracted from Battery level state of charge
SOC_SCALE_R_DIS_BATTERY 1 ! [D] Divided into (Battery level state of charge -
                          ! SOC_START_R_DIS_BATTERY)
TEMP_START_R_DIS_BATTERY 0 ; C ! [D] Subtracted from Temperature
TEMP_SCALE_R_DIS_BATTERY 1 ! [D] Divided into (Temperature -
                           ! TEMP_START_R_DIS_BATTERY)

! R_EFF_MOTOR: Motor efficiency (hybrid powertrain). Motor efficiency can be a
! nonlinear CARPET function of motor output torque and motor speed or a function of
! motor speed (CONSTANT, COEFFICIENT, or TABLE) multiplied by a function
! R_EFF_MOTOR_TORQUE of motor output torque (CONSTANT, COEFFICIENT, or TABLE).
! Alternatively, a custom equation can be defined at runtime. Motor efficiency from
! the calculation can be adjusted with R_EFF_MOTOR_GAIN and R_EFF_MOTOR_OFFSET. Motor
! speed used in the calculation can be adjusted with SPIN_SCALE_R_EFF_MOTOR and
! SPIN_START_R_EFF_MOTOR. Motor output torque used in the calculation can be adjusted
! with TORQUE_SCALE_R_EFF_MOTOR and TORQUE_START_R_EFF_MOTOR.

! Row 1 has "0" (place holder) followed by 23 values of motor output torque (N-m).
! Other rows have motor speed (rpm) followed by 23 values of Motor efficiency (-).
R_EFF_MOTOR_CARPET 2D_LINEAR
 0, -305, -275, -245, -215, -185, -155, -125, -95, -65, -35, -5, 0, 5, 35, 65, 95, 125, 155, 185, 215, 245, 275, 305
