! MZ_TIRE, STI_TYPARR, and Z_PROFILE

OPT_TIRE_MODEL(1)   1 ! Internal tire shear-model option, front tire: 4 -> tabular
                      ! with camber extensions; 0 -> fully external model; 1 ->
                      ! Magic Formula for Fx, Fy, and Mz (BikeSim 1.0); 2 ->
                      ! built-in lags; 3 -> built-in for Fx, My, and lags; 5 -> TNO
                      ! Delft-Tyre; 6 -> COSIN FTire; 7 -> third-party STI tire
                      ! model [I]
FZ_MAX(1)        7000 ; N ! This is the maximum limit of the vertical force, which
                      ! is an input to the functions of the tire share forces and
                      ! moments. But, the actual vertical force is not limited by
                      ! this parameter
FZ_REF(1)        6000 ; N ! [D] Reference vertical force: Not used directly in the
                      ! VS Math Model; provided as a standard reference for
                      ! advanced users to scale other parameters and Configurable
                      ! Functions for this tire
IYY_WHL(1)        0.4 ; kg-m2 ! Spin inertia of front wheel [I]
M_WHL(1)            7 ; kg ! Mass of front wheel [I]
RAD_TC(1)          50 ; mm ! Crown radius of tire [I]
RRE(1)            300 ; mm ! Effective rolling radius (Vx/AVy) [I]
RR_C(1)         0.002 ; - ! Rolling-resistance coefficient Fx_rr = Fz*RR_surf*(RR_c
                      ! + RR_v*Vx)
RR_V(1)       1.5e-05 ; h/km ! Rolling-res. speed coefficient Fx_rr =
                      ! Fz*RR_surf*(RR_c + RR_v*Vx)
VHIGH_KAPPA(1)     15 ; km/h ! [D] Max. speed for full long. relaxation
VLOW_ALPHA(1)       5 ; km/h ! Min. speed for full lat. relaxation

